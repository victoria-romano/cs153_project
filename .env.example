PORT=5173

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=sk-your-openai-key
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TEXT_MODEL=gpt-4.1-mini

# Separate categories with pipes. These power the focus-area picker and theme analysis.
POLICY_CATEGORIES=Medicaid Access|Insurance Denials|Cost of Care|Transportation|Language Barriers|Food Insecurity|Disability Access|Other

# Replace these prompts with your final versions.
SUMMARY_PROMPT=Summarize this doctor story in 2-4 concise sentences. Preserve the policy-relevant facts.
CATEGORY_PROMPT=Choose the one category that best fits this story. Return only the category name.
POLICY_PROMPT=Write a formal policy proposal. Use only the supplied transcript evidence, cite supporting story IDs inline, and include a short evidence section.
